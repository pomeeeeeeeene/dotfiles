#!/bin/sh
set -eu

self=$0
case "$self" in
  */*) ;;
  *) self=$(command -v -- "$self" 2>/dev/null || printf '%s' "$self") ;;
esac
if [ -L "$self" ]; then
  target=$(readlink "$self")
  case "$target" in
    /*) self=$target ;;
    *) self=$(dirname "$self")/$target ;;
  esac
fi

script_dir=$(cd "$(dirname "$self")" && pwd)
repo_root=$script_dir
while [ "$repo_root" != "/" ] && [ ! -f "$repo_root/tools/dotfiles-cli/Cargo.toml" ]; do
  repo_root=$(dirname "$repo_root")
done
if [ ! -f "$repo_root/tools/dotfiles-cli/Cargo.toml" ]; then
  echo "dotfiles repository root not found from $script_dir" >&2
  exit 1
fi
bin="$repo_root/tools/dotfiles-cli/target/release/yazi-session"

if [ ! -x "$bin" ]; then
  echo "dotfiles-cli is not built. Run:" >&2
  echo "  cargo build --release --manifest-path \"$repo_root/tools/dotfiles-cli/Cargo.toml\"" >&2
  exit 1
fi

exec "$bin" "$@"
